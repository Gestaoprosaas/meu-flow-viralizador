# =========================================================================
# VIRALFORGE AI - ENVIRONMENT VARIABLES EXAMPLE
# Configure these variables in your hosting environment (Supabase, Vercel, etc.)
# For local AI Studio deployment, GEMINI_API_KEY is configured in Secrets panel.
# =========================================================================

# 1. Supabase BaaS (Auth, Database, Storage)
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-role-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# 2. AI APIs (Used for texts, voice covers, videos, and images)
GEMINI_API_KEY="MY_GEMINI_API_KEY"
OPENAI_API_KEY="sk-proj-..."
ELEVENLABS_API_KEY="el-api-..."
KLING_API_KEY="kl-..."

# 3. Brazilian Payments gateway (Asaas API Sandbox / Production)
ASAAS_API_KEY="asaas_api_key_here"
ASAAS_WEBHOOK_SECRET="asaas_webhook_sha_signature"

# 4. Email Transactional Delivery (Resend API)
RESEND_API_KEY="re-..."

# 5. Application Context URL for webhooks and oauth redirects
APP_URL="MY_APP_URL"
NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# 6. Flowy AI Image Generator External Platform Link
NEXT_PUBLIC_FLOWY_URL="https://COLOQUE_O_LINK_AQUI"

# 7. TikTok Shop Analytics Integration API Key
# Put your EchoTik, Shoplus, or Scraper API token here to synchronize real-time product indexes
TIKTOK_DATA_API_KEY="your_tiktok_data_api_key"

# 8. Applyfy Webhook Secret for signature validation
APPLYFY_WEBHOOK_SECRET="your-applyfy-webhook-secret-here"
NEXT_PUBLIC_APPLYFY_URL_STARTER=https://applyfy.com.br/checkout/SEU_ID_STARTER
NEXT_PUBLIC_APPLYFY_URL_PRO=https://applyfy.com.br/checkout/SEU_ID_PRO


